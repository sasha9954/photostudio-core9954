PS_ENV=dev

# Required backend network config
# PUBLIC_BASE_URL: what frontend/clients use to reach backend static/API from outside.
# COMFY_BASE_URL: production generation target (backend -> remote ComfyUI_srv:8000).
PUBLIC_BASE_URL=http://BACKEND_HOST:8000
COMFY_BASE_URL=http://SERVER_IP:8000

# Allowed browser origins for frontend -> backend API.
# Include all real frontend origins you use (local, loopback, LAN IP/hostname).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://BACKEND_HOST:5173

# Optional: ComfyUI_lab for manager/manual tests only (not production generation target)
COMFY_LAB_URL=http://SERVER_IP:8001

# Optional providers
GEMINI_API_KEY=
KIE_API_KEY=
PIAPI_API_KEY=

GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
GEMINI_TEXT_MODEL_FALLBACK=gemini-3-flash-preview
GEMINI_TEXT_MODEL_FALLBACK_CHAIN=gemini-3-flash-preview,gemini-2.5-pro
